db.exec(`
  CREATE TABLE IF NOT EXISTS agent_trust (
    agent_name TEXT PRIMARY KEY,
    moltbook_handle TEXT,
    moltbook_verified BOOLEAN DEFAULT 0,
    moltbook_karma INTEGER DEFAULT 0,
    trust_score REAL DEFAULT 0.5,
