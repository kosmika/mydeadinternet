    const runs = db.prepare('SELECT * FROM feed_runs WHERE feed_id = ? ORDER BY started_at DESC LIMIT 5').all(feed.id);
    const itemCount = db.prepare('SELECT COUNT(*) as c FROM feed_items WHERE feed_id = ?').get(feed.id);
