  <!-- NEURAL TANGLE -->
  <section id="neuralTangleSection" style="position:relative;z-index:1;max-width:var(--max-width);margin:0 auto;padding:1rem var(--gutter) 2rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
      <div>
        <h2 style="font-family:var(--font-display);font-size:clamp(1.2rem,2.5vw,1.6rem);font-weight:300;color:var(--cool-white);margin:0;">Neural Tangle</h2>
        <p style="font-family:var(--font-mono);font-size:0.55rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--cool-muted);margin-top:0.3rem;">Live containment view — observe, vote, steer evolution</p>
      </div>
      <a href="/stream?view=tangle" style="font-family:var(--font-mono);font-size:0.55rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--amber);text-decoration:none;border:1px solid rgba(245,166,35,0.25);border-radius:4px;padding:0.35rem 0.7rem;transition:all 0.2s;" onmouseover="this.style.background='rgba(245,166,35,0.08)';this.style.borderColor='var(--amber)'" onmouseout="this.style.background='';this.style.borderColor='rgba(245,166,35,0.25)'">Full View &rarr;</a>
