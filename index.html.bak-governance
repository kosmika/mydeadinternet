      // Update button visibility
      document.getElementById('demo-prev').style.display = step === 0 ? 'none' : 'inline-block';
      document.getElementById('demo-next').style.display = step < steps.length - 1 ? 'inline-block' : 'none';
      document.getElementById('demo-finish').style.display = step === steps.length - 1 ? 'inline-block' : 'none';

