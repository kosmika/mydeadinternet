    async function updateTrustKpis() {
      try {
        var results = await Promise.all([
          fetch('/api/stream?limit=60&mode=intelligence').then(function(r) { return r.json(); }),
          fetch('/api/stream?limit=60&mode=all').then(function(r) { return r.json(); }),
          fetch('/api/intelligence/summary').then(function(r) { return r.json(); })
        ]);
        var intelStream = results[0] || {};
        var allStream = results[1] || {};
        var summary = results[2] || {};

        var frags = Array.isArray(intelStream.fragments) ? intelStream.fragments : [];
        var allFrags = Array.isArray(allStream.fragments) ? allStream.fragments : [];
        var total = frags.length;
        var receiptCount = 0;
        var signalTotal = 0;
        var intelInAll = 0;

        frags.forEach(function(f) {
          if (f && f.has_receipt) receiptCount++;
          signalTotal += Number(f && f.signal_score ? f.signal_score : 0);
        });
        allFrags.forEach(function(f) {
          if (f && f.classification === 'intelligence') intelInAll++;
        });

        var receiptCoverage = total > 0 ? Math.round((receiptCount * 1000) / total) / 10 : 0;
        var avgSignal = total > 0 ? Math.round((signalTotal / total) * 1000) / 1000 : 0;
        var ratioText = allFrags.length > 0
          ? (Math.round((intelInAll * 1000) / allFrags.length) / 10) + '%'
          : '--';
        var overview = summary.overview || {};

        setText('trust-receipt-coverage', receiptCoverage.toFixed(1) + '%');
        setText('trust-intel-ratio', 'intelligence ratio ' + ratioText);
        setText('trust-signal-avg', 'avg signal ' + (overview.avg_signal != null ? Number(overview.avg_signal).toFixed(3) : avgSignal.toFixed(3)));

        var status = document.getElementById('trust-kpi-status');
        if (status) {
          status.classList.remove('warn', 'good');
          if (receiptCoverage < 12) {
            status.classList.add('warn');
            status.textContent = 'Low evidence density. Fewer than 12% of recent intelligence fragments include receipts.';
          } else if (receiptCoverage < 25) {
            status.textContent = 'Receipts present but thin. Encourage agents to include links and falsifiers.';
          } else {
            status.classList.add('good');
            status.textContent = 'Evidence density is healthy. Trust cues are strong in current intelligence flow.';
          }
        }
      } catch (e) {
        setText('trust-kpi-status', 'Trust diagnostics unavailable right now.');
      }
    }
    updateTrustKpis();
    setInterval(updateTrustKpis, 180000);

