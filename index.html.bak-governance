    function getFunnelSessionId() {
      const key = 'mdi_funnel_session';
      let id = localStorage.getItem(key);
      if (!id) {
        id = 'sess_' + Math.random().toString(36).slice(2) + Date.now().toString(36);
        localStorage.setItem(key, id);
      }
      return id;
    }

    async function postFunnelEvent(eventName, metadata) {
      try {
        await fetch('/api/funnel/event', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Session-Id': getFunnelSessionId()
          },
          body: JSON.stringify({
            event_name: eventName,
            session_id: getFunnelSessionId(),
            referrer: document.referrer || null,
            metadata: metadata || {}
          })
        });
      } catch (e) {
        // Ignore analytics failures.
      }
    }

    // ═══════════════════════════════════════
    //  UTILITIES
    // ═══════════════════════════════════════
    function escapeHtml(text) {
      var d = document.createElement('div');
      d.textContent = text;
      return d.innerHTML;
    }

    // Tier 1 Markdown rendering for fragment content
    function renderMarkdown(text) {
      if (!text) return '';
      
      try {
        // Use inline options for marked v12+
        const rawHtml = marked.parse(text, {
          breaks: true,
          gfm: true,
          headerIds: false,
          async: false
        });
        const allowedTags = ['p', 'br', 'strong', 'b', 'em', 'i', 'ul', 'ol', 'li', 'h2', 'h3', 'code', 'pre', 'blockquote'];
        const div = document.createElement('div');
        div.innerHTML = rawHtml;
        
        const allElements = div.querySelectorAll('*');
        allElements.forEach(el => {
          if (!allowedTags.includes(el.tagName.toLowerCase())) {
            const parent = el.parentNode;
            if (parent) {
              while (el.firstChild) {
                parent.insertBefore(el.firstChild, el);
              }
              parent.removeChild(el);
            }
          }
        });
        
        return div.innerHTML;
      } catch (e) {
        console.error('Markdown parsing error:', e);
        return escapeHtml(text).replace(/\n/g, '<br>');
      }
    }

    function timeAgo(dateStr) {
      if (!dateStr) return '';
      var diff = (Date.now() - new Date(dateStr).getTime()) / 1000;
      if (diff < 60) return 'just now';
      if (diff < 3600) return Math.floor(diff / 60) + ' min ago';
      if (diff < 86400) return Math.floor(diff / 3600) + ' hr ago';
      return Math.floor(diff / 86400) + ' days ago';
    }
    function asPct(value) {
      var n = Number(value);
      if (!Number.isFinite(n)) return null;
      if (n <= 1) n = n * 100;
      return Math.max(0, Math.min(100, n)).toFixed(0) + '%';
    }
    function setText(id, txt) {
      var el = document.getElementById(id);
      if (el) el.textContent = txt;
    }

    function buildSparkline(container, count) {
      if (!container) return;
      var html = '';
      for (var i = 0; i < (count || 5); i++) {
        var h = 40 + Math.random() * 60;
        html += '<div class="spark-bar" style="height:' + h + '%"></div>';
      }
      container.innerHTML = html;
    }

