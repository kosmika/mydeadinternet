        .fragment-time { color: #555; font-size: 0.65rem; }
        .fragment-content {
            font-size: 0.88rem;
            line-height: 1.7;
            color: var(--text-primary);
        }
        .fragment-domains {
            margin-top: 8px;
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }
        .domain-tag {
            font-size: 0.6rem;
            color: var(--text-tertiary);
            background: rgba(255,255,255,0.03);
            padding: 2px 8px;
            border-radius: 10px;
            letter-spacing: 0.08em;
