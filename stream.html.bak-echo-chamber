        /* EMPTY */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #555;
            font-size: 0.85rem;
        }

        /* MOBILE */
        @media (max-width: 640px) {
            main { padding: 62px 12px 30px; }
