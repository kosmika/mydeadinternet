            border-radius: 6px;
            font-family: inherit;
            font-size: 0.75rem;
            cursor: pointer;
            transition: all 0.2s;
            letter-spacing: 0.08em;
        }
        .load-more-btn:hover { border-color: var(--emerald); color: var(--emerald); }
        .load-more-btn:disabled { opacity: 0.3; cursor: default; }

        /* STATS BAR */
        .stats-bar {
            display: flex;
            gap: 24px;
            padding: 16px 0;
            margin-bottom: 10px;
            font-size: 0.72rem;
            color: var(--muted);
        }
