            .stream-header h1 { font-size: 1.2rem; }
            .fragment { padding: 14px 12px; }
            .fragment-content { font-size: 0.82rem; }
            .stats-bar { flex-wrap: wrap; gap: 12px; }
            .filter-pills { gap: 4px; }
            .filter-pill { padding: 4px 9px; font-size: 0.65rem; }
        }

        /* MARKDOWN FORMATTING - Tier 1 */
        .fragment-content h2, .fragment-content h3 {
            font-family: var(--font-display, 'Crimson Pro', serif);
            font-weight: 400;
            margin: 1rem 0 0.5rem;
            color: var(--cool-white);
        }
        .fragment-content h2 { font-size: 1.1rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 0.3rem; }
        .fragment-content h3 { font-size: 0.95rem; color: var(--cool-muted); }
        .fragment-content ul, .fragment-content ol {
            margin: 0.5rem 0;
            padding-left: 1.5rem;
        }
        .fragment-content li {
            margin: 0.25rem 0;
            line-height: 1.6;
        }
        .fragment-content ul li { list-style-type: disc; }
        .fragment-content ol li { list-style-type: decimal; }
        .fragment-content strong, .fragment-content b {
            font-weight: 600;
            color: var(--cool-white);
        }
        .fragment-content em, .fragment-content i {
            font-style: italic;
            color: var(--cool-muted);
        }
        .fragment-content p {
            margin: 0.5rem 0;
        }
        .fragment-content p:first-child {
            margin-top: 0;
        }
        .fragment-content code {
            font-family: var(--font-mono, 'Space Mono', monospace);
            background: rgba(255,255,255,0.05);
            padding: 0.1rem 0.3rem;
            border-radius: 3px;
            font-size: 0.85em;
            color: var(--amber);
        }
        .fragment-content blockquote {
            border-left: 2px solid var(--amber);
            margin: 0.5rem 0;
            padding-left: 1rem;
            color: var(--cool-muted);
            font-style: italic;
        }
        .stream-mode-btn.active {
            background: #f5a623 !important;
            color: #0a0a0a !important;
            border-color: #f5a623 !important;
        }
    </style>
