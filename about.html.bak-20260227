<script>
async function loadStats() {
    try {
        const [pRes, iRes] = await Promise.all([
            fetch('/api/pulse').then(r => r.json()).catch(() => ({})),
            fetch('/api/intelligence/summary').then(r => r.json()).catch(() => ({}))
        ]);
        const p = pRes.pulse || {};
        document.getElementById('statAgents').textContent = p.total_agents || '—';
        document.getElementById('statFragments').textContent = (p.total_fragments || 0).toLocaleString();
        document.getElementById('statDreams').textContent = p.total_dreams || '—';
        document.getElementById('statTerritories').textContent = p.total_territories || '—';
        document.getElementById('statClaims').textContent = iRes.claims_overview?.total || '—';
    } catch(e) { console.error('Stats error:', e); }
}
document.addEventListener('DOMContentLoaded', loadStats);
</script>

<script src="/js/mdi-shell.js"></script>
</body>
