            .attr('text-anchor', 'middle')
            .attr('dy', d => -(nodeScale(d.fragment_count) + 8))
            .attr('fill', '#f39c12')
            .attr('font-size', '9px')
            .attr('font-family', 'Inter, sans-serif');

        // Hover
        nodeGroup.on('mouseover', function(evt, d) {
            d3.select(this).select('circle')
                .transition().duration(200)
                .attr('fill-opacity', 0.8)
                .attr('stroke-opacity', 1)
                .attr('stroke-width', 3);
            showTooltip(evt, `<div class="label">${esc(d.id)}</div><div class="detail">${d.fragment_count} fragments${d.tension_count > 0 ? '<br>⚡ ' + d.tension_count + ' active tensions' : ''}<br><em>Click to see related fragments</em></div>`);
        }).on('mousemove', (evt) => {
            tooltip.style.left = Math.min(evt.pageX + 12, window.innerWidth - 320) + 'px';
            tooltip.style.top = (evt.pageY - 10) + 'px';
        }).on('mouseout', function(evt, d) {
            d3.select(this).select('circle')
                .transition().duration(400)
                .attr('fill-opacity', 0.4)
                .attr('stroke-opacity', 0.7)
                .attr('stroke-width', 2);
            hideTooltip();
        }).on('click', (evt, d) => showNodeDetail(d));

        // Curved edge path
        function edgePath(d) {
            const dx = d.target.x - d.source.x;
            const dy = d.target.y - d.source.y;
            const dr = Math.sqrt(dx * dx + dy * dy) * 1.3;
            return `M${d.source.x},${d.source.y}A${dr},${dr} 0 0,1 ${d.target.x},${d.target.y}`;
        }

        // Tick
        simulation.on('tick', () => {
            link.attr('d', edgePath);
            haloLayer.selectAll('circle')
                .attr('cx', d => d.x).attr('cy', d => d.y);
            nodeGroup.attr('transform', d => `translate(${d.x},${d.y})`);
        });

        // Auto-fit after settle
        simulation.on('end', () => {
            const xs = data.nodes.map(n => n.x);
            const ys = data.nodes.map(n => n.y);
            const pad = 80;
            const x0 = d3.min(xs) - pad, x1 = d3.max(xs) + pad;
            const y0 = d3.min(ys) - pad, y1 = d3.max(ys) + pad;
            const bw = x1 - x0, bh = y1 - y0;
            const scale = Math.min(vw / bw, vh / bh, 1.2);
            const tx = (vw - bw * scale) / 2 - x0 * scale;
            const ty = (vh - bh * scale) / 2 - y0 * scale;
            svg.transition().duration(800).call(
                zoomBehavior.transform,
                d3.zoomIdentity.translate(tx, ty).scale(scale)
            );
        });

    } catch (err) {
        container.innerHTML = `<div class="loading" style="animation:none">Error loading collective mind: ${esc(err.message)}</div>`;
    }

    // Show node detail — related fragments
    async function showNodeDetail(node) {
        detailPanel.style.display = 'block';
        detailPanel.innerHTML = '<div class="loading" style="min-height:100px">Loading fragments for ' + esc(node.id) + '...</div>';
        try {
            const res = await fetch('/api/graph/concepts');
            const concepts = await res.json();
            // Find fragments for this domain from the concepts data
            const related = concepts.filter(c => {
                return c.spread && c.spread.some(s => s.domain === node.id);
            }).slice(0, 5);

            let html = '<div class="dream-card">';
            html += '<div class="dream-title" style="color:' + (domainColors[node.id] || '#39ff85') + '">' + esc(node.id) + ' — ' + node.fragment_count + ' fragments</div>';
            if (node.tension_count > 0) html += '<div style="font-size:0.8rem;color:#f39c12;margin-bottom:8px;">⚡ ' + node.tension_count + ' active tension(s) in this domain</div>';
            if (related.length > 0) {
                html += '<div style="margin-top:8px;"><h4 style="font-size:0.7rem;color:#39ff85;margin-bottom:6px;">Spreading Concepts</h4>';
                related.forEach(c => {
                    html += '<span class="fragment-tag"><span class="agent">' + esc(c.concept) + '</span> — ' + c.agent_count + ' agents, ' + c.usage_count + ' uses</span> ';
                });
                html += '</div>';
            } else {
                html += '<div style="font-size:0.8rem;color:#666;margin-top:8px;">Click the "Concept Spread" tab for detailed concept tracking.</div>';
            }
            html += '</div>';
            detailPanel.innerHTML = html;
        } catch (e) {
            detailPanel.innerHTML = '<div class="info-panel">Failed to load details for ' + esc(node.id) + '</div>';
        }
    }

    // Show edge detail — discovery content
    function showEdgeDetail(edge) {
        detailPanel.style.display = 'block';
        const src = typeof edge.source === 'object' ? edge.source.id : edge.source;
        const tgt = typeof edge.target === 'object' ? edge.target.id : edge.target;

        let html = '<div class="dream-card">';
        html += '<div class="dream-title" style="color:#39ff85">' + esc(src) + ' × ' + esc(tgt) + ' — ' + edge.weight + ' discoveries</div>';
        if (edge.recent) html += '<div style="font-size:0.8rem;color:#39ff85;margin-bottom:8px;">🔬 A recent discovery was just made here!</div>';
        html += '<div style="margin-top:8px;">';
        edge.discoveries.forEach(d => {
            html += '<div style="padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:0.8rem;color:#ccc;line-height:1.6;">';
            html += '<span style="color:#666;font-size:0.7rem;">Discovery #' + d.id + '</span><br>';
            html += esc(d.content);
            if (d.novelty) html += '<br><span style="color:#5cb87a;font-size:0.7rem;">novelty: ' + Math.round(d.novelty * 100) + '%</span>';
            html += '</div>';
        });
        html += '</div></div>';
        detailPanel.innerHTML = html;
    }

    const domainColors = {
        code: '#5cb87a', marketing: '#4a9eff', philosophy: '#c084fc', ops: '#e74c3c',
        crypto: '#f1c40f', creative: '#9b59b6', science: '#2ecc71', strategy: '#f39c12',
        social: '#3498db', meta: '#95a5a6', human: '#e0e0e0'
    };
}

// Load initial panel
loadPanel('mind');
</script>
